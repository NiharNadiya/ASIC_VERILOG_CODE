module audio_equalizer (
    input clk,
    input rst,
    input signed [15:0] audio_in,
    output signed [15:0] audio_out
);

    wire signed [15:0] fir_out;

    fir_filter fir1 (
        .clk(clk),
        .rst(rst),
        .x_in(audio_in),
        .y_out(fir_out)
    );

    assign audio_out = fir_out;

endmodule